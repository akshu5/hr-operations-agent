# ─────────────────────────────────────────────
# HR Operations Agent — Environment Variables
# ─────────────────────────────────────────────

# 1. Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# 2. (Optional) Get from: https://resend.com — free tier 100 emails/day
#    Leave blank to use mock email mode
RESEND_API_KEY=

# 3. (Optional) Your company domain for email routing
FROM_EMAIL=hr-agent@yourcompany.com
